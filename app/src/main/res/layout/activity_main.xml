<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#18181A">

        <!-- Split-pane WebViews are added/removed here at runtime by PaneManager. -->
        <FrameLayout
            android:id="@+id/pane_slot"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Persistent bottom bar, hidden while in fullscreen (see MainActivity#handleToggleFullscreen). -->
        <WebView
            android:id="@+id/bar_webview"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#00000000" />

    </LinearLayout>

    <!-- Small floating button, shown only while fullscreenActive, that lets you
         exit fullscreen without the back button (see MainActivity#handleToggleFullscreen).
         Sits in this outer FrameLayout - not pane_slot - so PaneManager's
         removeAllViews()/render() churn on pane_slot never touches it. -->
    <ImageButton
        android:id="@+id/exit_fullscreen_button"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="16dp"
        android:padding="10dp"
        android:background="@drawable/bg_exit_fullscreen_button"
        android:src="@drawable/ic_exit_fullscreen"
        android:contentDescription="@string/exit_fullscreen"
        android:visibility="gone"
        android:elevation="8dp" />

</FrameLayout>
